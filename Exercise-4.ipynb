   "source": [
    "from sympy import *\n",
    "from sympy.logic.boolalg import *\n",
    "M, T, W = symbols('M T W')\n",
    "KB = (M | T) & ((M & ~W) | (~M & W)) & (T | W)\n",
    "print(\"Truth Table of KB\")\n",
    "\n",
    "for row in truth_table(KB,[M,T,W]):\n",
    "    print(row)"
   ]
  }
